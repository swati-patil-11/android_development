<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Contact Number -->

    <!-- Call Button -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="120dp"
        android:text="Selected Contact"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.476"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/call"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/call"
        android:background="@android:color/transparent"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/msg"/>

    <!-- Message Button -->
    <ImageButton
        android:id="@+id/msg"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/msg"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="@id/call"
        app:layout_constraintStart_toEndOf="@id/call"
        app:layout_constraintEnd_toStartOf="@id/wp"/>

    <!-- WhatsApp Button -->
    <ImageButton
        android:id="@+id/wp"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/wp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="@id/call"
        app:layout_constraintStart_toEndOf="@id/msg"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="selcted  contact"
        app:layout_constraintBottom_toTopOf="@+id/textView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>